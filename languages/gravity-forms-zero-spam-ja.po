msgstr "有効期限の単位"

#: includes/class-gf-zero-spam-addon.php:889
msgid "hours"
msgstr "時間"

#: includes/class-gf-zero-spam-addon.php:892
msgid "days"
msgstr "日"

#: includes/class-gf-zero-spam-addon.php:908
