msgstr "Pominięto [count] nieprawidłową wartość."

#: includes/class-gf-zero-spam-addon.php:279
msgctxt "The heading inside the email body."
msgid "Gravity Forms Spam Report"
msgstr "Raport spamu Gravity Forms"
